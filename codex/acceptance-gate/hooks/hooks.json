{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|^apply_patch$",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${PLUGIN_ROOT}/hooks/acceptance-evidence-gate-codex.js\"",
            "timeout": 30,
            "statusMessage": "Checking acceptance gate files"
          }
        ]
      }
    ]
  }
}
